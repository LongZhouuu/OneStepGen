# go to console.groq.com to register for a free key
GROQ_API_KEY=

# Run the API locally (from this aiTool folder), e.g.:
#   uvicorn main:app --reload --host 127.0.0.1 --port 8000
#
# Frontend “gate” password is NOT configured here — it lives in the project root .env:
#   VITE_SITE_ACCESS_PASSWORD=...
# Frontend API URL pointing at this server:
#   VITE_API_BASE_URL=http://127.0.0.1:8000