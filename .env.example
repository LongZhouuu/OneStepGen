# copy and create .env.development and .env.production
VITE_API_BASE_URL=

# Site gate (bundled — deters casual visitors only). Use 32+ random chars mix of A–Z a–z 0–9 symbols.
# Omit in local dev to skip the gate during development.
# Production: REQUIRED — build will show a blocking screen if unset.
#
# Strong example (rotate before use; never commit real values):
# VITE_SITE_ACCESS_PASSWORD=Gm8!zKp2#Lv9$nWx4&tRy7*Hq5%Uj3@Bc6^Na1
